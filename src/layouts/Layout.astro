---
import '../styles/global.css';
import config from '../data/config.json';
import communes from '../data/communes.json';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  activeTab?: string;
}

const { 
  title = "Monte-Escalier Vaucluse : Devis Gratuit & Installateur 84", 
  description = "Comparez gratuitement les installateurs de monte-escaliers en Vaucluse (84). Estimation d'aides (ANAH, APA 84), tarifs droits & courbes, devis rapides.", 
  canonicalUrl,
  activeTab
} = Astro.props;

const currentYear = new Date().getFullYear();
const canonical = canonicalUrl || `https://${config.domain}${Astro.url.pathname}`;

// Top 8 populated communes to display in the footer
const topCommunes = communes.slice(0, 8);
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>💜</text></svg>" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://monte-escalier-vaucluse.fr/images/hero-monte-escalier-vaucluse.png" />
    
    <!-- Security Header Metas (Cloudflare protection) -->
    <meta name="robots" content="index, follow" />
  </head>
  <body>
    <header>
      <div class="container header-inner">
        <a href="/" class="logo">
          <span>💜</span> Monte-Escalier Vaucluse
        </a>
        <nav class="header-nav" aria-label="Menu principal">
          <a href="/" class={activeTab === 'home' ? 'active' : ''}>Accueil</a>
          <a href="/guide-aides-monte-escalier-84/" class={activeTab === 'aides' ? 'active' : ''}>💶 Aides 84</a>
          <a href="/monte-escalier-mas-provencal/" class={activeTab === 'mas' ? 'active' : ''}>🏡 Mas Provençal</a>
          <a href="/tarifs/" class={activeTab === 'tarifs' ? 'active' : ''}>Tarifs 2026</a>
          <a href="/communes/" class={activeTab === 'communes' ? 'active' : ''}>Villes 84</a>
        </nav>
        <div>
          <a href="/devis/" class="btn-primary header-cta">Estimer mes aides &rarr;</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container footer-grid">
        <div class="footer-brand">
          <h3 style="margin-bottom:15px;">💜 Monte-Escalier Vaucluse</h3>
          <p style="font-size:15px; color:#A8A29E; line-height:1.6; margin-bottom:20px;">
            Le portail indépendant de comparaison pour sécuriser le maintien à domicile des seniors dans le département du Vaucluse (84). Estimation gratuite de subventions (MaPrimeAdapt', APA 84, Crédit d'impôt).
          </p>
          <p style="font-size:14px; color:#78716C;">
            Une initiative solidaire pour l'accessibilité senior en Provence-Alpes-Côte d'Azur.
          </p>
        </div>
        
        <div class="footer-links">
          <h3>Top Villes Vaucluse</h3>
          <ul>
            {topCommunes.map(c => (
              <li>
                <a href={`/monte-escalier-${c.slug}/`}>Monte-escalier {c.nom} ({c.codePostal})</a>
              </li>
            ))}
          </ul>
        </div>
        
        <div class="footer-links">
          <h3>Guides & Infos</h3>
          <ul>
            <li><a href="/guide-aides-monte-escalier-84/">Grille des aides financières 2026</a></li>
            <li><a href="/monte-escalier-mas-provencal/">Solutions pour mas provençal ancien</a></li>
            <li><a href="/tarifs/">Grille de prix par modèle</a></li>
            <li><a href="/communes/">Annuaire des communes du 84</a></li>
            <li><a href="/politique-confidentialite/">Politique de confidentialité</a></li>
            <li><a href="/mentions-legales/">Mentions légales</a></li>
          </ul>
        </div>
      </div>
      
      <div class="container footer-bottom">
        <p>&copy; {currentYear} monte-escalier-vaucluse.fr. Tous droits réservés.</p>
        <p style="font-size:13px; color:#78716C;">
          Comparateur gratuit sans engagement. Les estimations d'aides sont fournies à titre indicatif sous réserve d'audit technique RGE à domicile.
        </p>
      </div>
    </footer>

    <!-- Global exit intent modal popup component -->
    <ExitIntentPopup />
  </body>
</html>
